# Google OAuth 클라이언트 (Google Cloud Console → 사용자 인증 정보)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# scripts/get-refresh-token.js 로 발급받은 refresh token
GOOGLE_REFRESH_TOKEN=your-refresh-token

# Google AI Studio 에서 발급받은 Gemini API 키
GEMINI_API_KEY=your-gemini-api-key

# (선택) 등록 대상 Task 목록 이름. 비워두면 기본 목록(@default)에 등록
# TASK_LIST_TITLE=캘린더 준비 작업

# (선택) 말일 체크를 건너뛰고 강제로 실행 (로컬 테스트용)
# FORCE_RUN=true
